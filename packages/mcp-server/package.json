{
  "name": "@1mbrain/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for 1MBrain",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "1mbrain-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@1mbrain/sdk": "*",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
