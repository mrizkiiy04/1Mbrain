# 1MBrain API Configuration
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# ─── Database ──────────────────────────────────────────
# Options: "sqlite" | "postgres"
DB_PROVIDER=sqlite

# SQLite (used when DB_PROVIDER=sqlite)
SQLITE_PATH=./data/1mbrain.db

# PostgreSQL (used when DB_PROVIDER=postgres)
DATABASE_URL=postgresql://onemillionbrain:onemillionbrain@localhost:5432/onemillionbrain

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Embedding Provider ───────────────────────────────
# Options: "openai" | "ollama" | "claude"
EMBEDDING_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Claude / Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_EMBEDDING_MODEL=

# ─── Security ─────────────────────────────────────────
# Master API key for admin operations (generate keys, etc.)
MASTER_API_KEY=change-me-to-a-strong-random-string

# Dashboard browser connection defaults
NEXT_PUBLIC_1MBRAIN_API_URL=http://localhost:3100
NEXT_PUBLIC_1MBRAIN_AGENT_ID=default

# Encryption key for Memory Passport exports (AES-256)
EXPORT_ENCRYPTION_KEY=change-me-32-bytes-hex-string-ok

# ─── Google Drive Backup (optional) ──────────────────
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REDIRECT_URI=http://localhost:3100/auth/gdrive/callback
GDRIVE_REFRESH_TOKEN=
GDRIVE_ACCESS_TOKEN=
GDRIVE_BACKUP_FOLDER_ID=

# Auto-Summarization / Memory Consolidation
CONSOLIDATION_ENABLED=true
CONSOLIDATION_CRON="0 2 * * *"
CONSOLIDATION_THRESHOLD=50
CONSOLIDATION_MIN_AGE_DAYS=7
CONSOLIDATION_DECAY_CUTOFF=0.4
CONSOLIDATION_ARCHIVE_STRATEGY=decay
CONSOLIDATION_CLUSTER_STRATEGY=hybrid
CONSOLIDATION_DRY_RUN=false

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=debug

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Benchmark defaults
BENCH_LLM_EVAL=openai
BENCH_LLM_MODEL=gpt-4o-mini
BENCH_PROVIDERS=1mbrain_graph_full,1mbrain_vector_only,vector_baseline
BENCH_DATASET=claude-realistic-medium
